<!DOCTYPE html>
<html>
<head>

  <title>Lab Reset - NJ SecForge</title>

  <style>
        body {
        background:#f5f7fb;
        margin:0;
        padding:0;
        }
    .reset-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 65vh;
    }

    .reset-card {
      background: white;
      padding: 35px;
      border-radius: 14px;
      box-shadow: 0 6px 18px rgba(0,0,0,0.1);
      text-align: center;
      max-width: 450px;
    }

    .reset-card h2 {
      margin-bottom: 10px;
    }

    .reset-btn {
      display: inline-block;
      margin-top: 20px;
      padding: 10px 18px;
      background: #5C6BC0;
      color: white;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
    }

    .reset-btn:hover {
      background: #3f51b5;
    }
  </style>
<link rel="stylesheet" href="/global.css">
</head>

<body>

<div class="container">
<%- include('partials/header') %>
  <div class="reset-wrapper">

    <div class="reset-card">

      <h2>🔄 <%= labName.toUpperCase() %> Reset Successful</h2>

      <p>The lab environment and progress have been restored.</p>

      <a class="reset-btn" href="/lab/<%= labName %>">
        Return to Lab →
      </a>

      <br><br>

      <a href="/">🏠 Back to Dashboard</a>

    </div>

  </div>

</div>

<%- include('partials/footer') %>

</body>
</html>